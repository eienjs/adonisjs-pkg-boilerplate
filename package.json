{
  "name": "@eienjs/adonisjs-pkg-boilerplate",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.9.0",
  "description": "A opinionated boilerplate for AdonisJS packages",
  "author": "Fernando Isidro <luffynando@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/eienjs/adonisjs-pkg-boilerplate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eienjs/adonisjs-pkg-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/eienjs/adonisjs-pkg-boilerplate/issues"
  },
  "keywords": [
    "adonis",
    "adonisjs",
    "adonis-framework"
  ],
  "exports": {
    ".": "./build/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "is-in-ci || husky",
    "changelog": "auto-changelog -u -p",
    "commitlint": "commitlint --edit",
    "index:commands": "adonis-kit index build/commands",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts",
    "test:coverage": "c8 pnpm run test",
    "tool:code": "pnpm run lint:check && pnpm run typecheck",
    "tool:build": "pnpm run tool:code && pnpm run test",
    "prebuild": "pnpm run tool:code",
    "build": "tsdown",
    "release": "release-it"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/core": "^7.3.4"
  },
  "peerDependenciesMeta": {
    "@adonisjs/assembler": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/core": "^7.3.4",
    "@adonisjs/eslint-plugin": "^2.2.2",
    "@adonisjs/tsconfig": "^2.0.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eienjs/eslint-config": "^2.1.1",
    "@japa/assert": "^4.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/node": "^24.13.2",
    "auto-changelog": "^2.6.0",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-erasable-syntax-only": "^0.4.2",
    "husky": "^9.1.7",
    "is-in-ci": "^2.0.0",
    "release-it": "^20.2.1",
    "tsdown": "^0.22.3",
    "tsdown-stale-guard": "^0.1.2",
    "typescript": "^6.0.3"
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "exclude": [
      "bin/**",
      "tests/**"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "auto-changelog": {
    "template": "keepachangelog",
    "hideCredit": true,
    "commitLimit": false
  },
  "release-it": {
    "git": {
      "commit": true,
      "tag": true,
      "push": true,
      "requireCleanWorkingDir": true,
      "commitMessage": "chore(release): :tada: v${version}",
      "tagAnnotation": "chore(release): :tada: v${version}"
    },
    "github": {
      "release": true,
      "web": true,
      "releaseName": "Release v${version}"
    },
    "npm": {
      "publish": true,
      "publishPackageManager": "pnpm",
      "publishArgs": [
        "--no-git-checks"
      ]
    },
    "hooks": {
      "before:init": [
        "pnpm run lint:check",
        "pnpm run typecheck",
        "pnpm test"
      ],
      "after:bump": [
        "pnpm run build",
        "pnpm run changelog"
      ]
    }
  }
}
